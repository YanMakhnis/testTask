<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="002" author="yanmakhnis">
        <createTable tableName="hotel_amenities">
            <column name="hotel_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_hotel_amenities" references="hotels(id)"/>
            </column>
            <column name="amenity" type="VARCHAR(255)"/>
        </createTable>

        <rollback>
            <dropTable tableName="hotel_amenities"/>
        </rollback>
    </changeSet>

</databaseChangeLog>